# ==========================================
# Server Configuration
# ==========================================
PORT=3000
# Use '*' for local development, or specify your frontend URL in production (e.g., http://localhost:5173)
CORS_ORIGIN=*

# ==========================================
# Database Configuration
# ==========================================
# Replace <username>, <password>, and <cluster-url> with your MongoDB credentials
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-url>/finance-dashboard"

# ==========================================
# JWT Authentication
# ==========================================
# Generate secure random strings for these in production (e.g., using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)

# Access Token (Short-lived, used for API requests)
ACCESS_TOKEN_SECRET_KEY="your_super_secret_access_key_here"
ACCESS_TOKEN_EXPIRY="15m"  # e.g., 15m, 1h

# Refresh Token (Long-lived, used to get new access tokens)
REFRESH_TOKEN_SECRET_KEY="your_super_secret_refresh_key_here"
REFRESH_TOKEN_EXPIRY="7d"  # e.g., 7d, 30d